# ImmoApp — Odoo batch configuration
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# Odoo SaaS connection
ODOO_URL=https://dominys.odoo.com
ODOO_DB=dominys
ODOO_USER=rg@gillet.consulting
ODOO_APIKEY=8303939fa526e846498cc3105be81222205e5c10

# Odoo Studio model technical names
# Check: Paramètres -> Technique -> Modèles -> search "immobilier" -> copy technical name
# Tek-app yaklaşımı: satış ve kira aynı modelde (x_transaction_type alanıyla ayrılır)
# batch.py → ODOO_MODEL kullanır, x_transaction_type='vente' kayıtlarını filtreler
# batch_rent.py → ODOO_RENT_MODEL kullanır, x_transaction_type='location' kayıtlarını filtreler
ODOO_MODEL=x_estimation
ODOO_RENT_MODEL=x_estimation

# Prediction API base URL (localhost if API runs on same VPS)
API_URL=http://localhost:5000/predict
