# ImmoApp — Odoo batch configuration
# Copy this file to .env and fill in your credentials.
# Never commit .env to git.

# Odoo SaaS connection
ODOO_URL=https://YOUR-COMPANY.odoo.com
ODOO_DB=YOUR-DB-NAME
ODOO_USER=YOUR-EMAIL@example.com
ODOO_APIKEY=YOUR-ODOO-API-KEY

# Odoo Studio model technical names
# Check: Paramètres -> Technique -> Modèles -> search "immobilier" -> copy technical name
ODOO_MODEL=x_immobilier          # sale price estimation app
ODOO_RENT_MODEL=x_immobilier_loyer  # rental estimation app

# Prediction API base URL (localhost if API runs on same VPS)
API_URL=http://localhost:5000/predict
